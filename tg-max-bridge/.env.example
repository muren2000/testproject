# Токен Telegram-бота — получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# Токен MAX-бота — получить у @masterbot в MAX (или на dev.max.ru)
MAX_BOT_TOKEN=

# ID связываемых чатов. Оставьте пустыми при первом запуске:
# мост напечатает ID в лог, когда вы напишете что-нибудь в чатах с ботами.
TELEGRAM_CHAT_ID=
MAX_CHAT_ID=

# Направление пересылки: both | tg_to_max | max_to_tg
BRIDGE_DIRECTION=both

# Подписывать сообщения именем автора (1/0)
BRIDGE_SHOW_AUTHOR=1

# Файл базы соответствий id сообщений (нужен для правок/удалений/ответов)
BRIDGE_DB_PATH=bridge.sqlite3
